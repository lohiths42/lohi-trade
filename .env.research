# ─────────────────────────────────────────────────────────────────────────────
# Lohi-Research Environment — Active Configuration
#
# This file is loaded by start-research.sh and the gateway at boot.
# Secrets here are NEVER committed to git (listed in .gitignore).
#
# TWO PATHS TO GET RESEARCH WORKING:
#
#   Path A (Cloud, fast, free tier):
#     1. Sign up at https://build.nvidia.com
#     2. Generate an API key
#     3. Set NVIDIA_NIM_API_KEY below
#     4. Leave LOHI_RESEARCH_OFFLINE=false
#
#   Path B (Local, fully private, no internet):
#     1. Install Ollama: https://ollama.com/download
#     2. Run: ollama pull gemma3:12b  (or llama3.1:8b)
#     3. Set LOHI_RESEARCH_OFFLINE=true below
#     4. NVIDIA_NIM_API_KEY can stay blank
#
# ─────────────────────────────────────────────────────────────────────────────

# ─── LLM Provider Key ────────────────────────────────────────────────────────
# Required for cloud LLM (Path A). Leave blank for offline/Ollama (Path B).
#
# 🔐 SECURITY: API keys were exposed in chat. ROTATE YOUR KEY IMMEDIATELY:
#   1. Go to https://build.nvidia.com → API Keys
#   2. Delete all exposed keys
#   3. Generate a NEW key
#   4. Paste below: NVIDIA_NIM_API_KEY=nvapi-YOUR_NEW_KEY_HERE
#   5. NEVER commit this file (.gitignore protects it)
#
# See NVIDIA_NIM_INTEGRATION.md for detailed setup instructions.
# OpenAI SDK support: python test_nvidia_nim_openai.py "Your question"
#
NVIDIA_NIM_API_KEY=

# ─── Offline Mode ────────────────────────────────────────────────────────────
# Set to "true" to use Ollama + local embeddings (no internet, no key needed).
# Set to "false" to use NVIDIA NIM cloud (requires valid key above).
LOHI_RESEARCH_OFFLINE=false

# ─── Optional: Override Ollama model (only used when offline=true) ────────────
# LOHI_RESEARCH_OLLAMA_MODEL=gemma3:12b
