# ─────────────────────────────────────────────────────────────────────────────
# Lohi-Research Environment Template (Task 18.3, design §7.2)
#
# Copy this file to ``.env.research`` in the repo root and fill in the keys
# your configuration uses. ``start-research.sh`` loads both ``.env`` and
# ``.env.research`` at boot and runs a pre-flight check that fails fast if
# a required key is missing — the error message names the missing key and
# the file it is expected in (Req 7.6).
#
# Scope: this file holds *secrets* only. Non-secret knobs (temperature,
# timeouts, ingest intervals, snapshot window) live in
# ``config/settings.yaml`` under the ``research:`` block. Secrets in
# ``settings.yaml`` are always ``${ENV_VAR}``-expanded from this file
# (Req 2.9 / Req 9.6).
#
# Key convention:
#   * REQUIRED — must be set for the default cloud path to start.
#   * OPTIONAL — only set when you enable the corresponding
#     provider/backend in ``config/settings.yaml``.
# ─────────────────────────────────────────────────────────────────────────────


# ─── REQUIRED — Default cloud LLM (NVIDIA NIM) ──────────────────────────────
# The default ``research.providers.chat.*``, ``.summarisation.*``, and
# ``.judge.*`` roles in ``config/settings.yaml`` all resolve to
# ``${NVIDIA_NIM_API_KEY}``. Set this key (free tier at
# https://build.nvidia.com) to run Lohi-Research with zero paid
# dependencies on the cloud path. If you switch every role to a
# different provider below, this key becomes optional.
NVIDIA_NIM_API_KEY=


# ─── OPTIONAL — Alternate cloud LLM providers ───────────────────────────────
# Only set these when you point one of ``research.providers.{chat,
# summarisation,judge}.provider`` at the corresponding adapter in
# ``config/settings.yaml``. Leaving an unused key blank is safe — the
# pre-flight check only validates keys referenced by the resolved
# provider config.

# OpenAI — research.providers.*.provider: openai
OPENAI_API_KEY=

# Anthropic Claude — research.providers.*.provider: anthropic
ANTHROPIC_API_KEY=

# Google Gemini — research.providers.*.provider: gemini
GOOGLE_API_KEY=

# Groq — research.providers.*.provider: groq
GROQ_API_KEY=

# Together — research.providers.*.provider: together
TOGETHER_API_KEY=

# OpenRouter — research.providers.*.provider: openrouter
OPENROUTER_API_KEY=


# ─── OPTIONAL — Offline-mode toggle ─────────────────────────────────────────
# When ``true``, ``start-research.sh`` skips every cloud provider and uses
# Ollama + local sentence-transformers (Req 7.5, Req 9.4). The launcher
# will ``ollama pull`` the configured model on boot; run the
# ``docker-compose.research.yml`` ``offline`` profile to host Ollama
# itself. The pre-flight check relaxes the required-key set in this
# mode — ``NVIDIA_NIM_API_KEY`` above is no longer required.
LOHI_RESEARCH_OFFLINE=false

# OPTIONAL — Override the Ollama model that ``start-research.sh``
# pulls on boot. Defaults to ``llama3.1:8b`` (design Open Issue #3).
# Only consulted when ``LOHI_RESEARCH_OFFLINE=true``.
# LOHI_RESEARCH_OLLAMA_MODEL=llama3.1:8b


# ─── OPTIONAL — External vector-store URLs ──────────────────────────────────
# Set only when ``research.vector_store.backend`` explicitly names a
# backend that needs an external service. The default auto-selection
# (``backend: auto``) picks Chroma (embedded, data/research/chroma/)
# when no external Postgres with pgvector is detected — no URL required
# (design §8, Req 2.13–2.15).

# Qdrant — set when ``research.vector_store.backend: qdrant``. Start the
# Qdrant container via ``docker-compose.research.yml --profile qdrant``.
QDRANT_URL=

# OPTIONAL — Override the gateway's DATABASE_URL used by the pgvector
# backend. Normally the pgvector adapter reuses the existing
# DATABASE_URL that the gateway already has. Uncomment only when you
# want Lohi-Research to talk to a *different* Postgres than the one
# LOHI-TRADE uses.
# LOHI_RESEARCH_DATABASE_URL=postgresql://user:pass@host:5432/db
