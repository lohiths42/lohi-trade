# Backend Gateway Environment Variables
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
DB_PATH=../data/lohi_trade.db
CONFIG_PATH=../config/settings.yaml
DATABASE_URL=postgresql://user:password@localhost:5432/lohitrade
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:5173

# Authentication
SECRET_KEY=change-me-in-production-use-at-least-32-chars
JWT_SECRET=change-me-in-production-use-at-least-32-chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
# TOTP_SECRET=  # Leave empty to disable TOTP

# Encryption
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
PAN_ENCRYPTION_KEY=
