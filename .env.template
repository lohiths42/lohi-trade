# LOHI-TRADE Environment Variables Template
# Copy this file to .env and update with your actual credentials

# Shoonya (Finvasia) Broker Credentials
SHOONYA_API_KEY=your_shoonya_api_key_here
SHOONYA_CLIENT_ID=your_shoonya_client_id_here
SHOONYA_PASSWORD=your_shoonya_password_here

# Angel One Broker Credentials (Backup)
ANGELONE_API_KEY=your_angelone_api_key_here
ANGELONE_CLIENT_ID=your_angelone_client_id_here
ANGELONE_PASSWORD=your_angelone_password_here

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Redis Configuration (optional, defaults to localhost:6379)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# PostgreSQL Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/lohitrade

# Environment
ENVIRONMENT=development  # development, paper_trading, production

# Authentication (Backend Gateway)
JWT_SECRET=your-secure-jwt-secret-at-least-32-chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
# TOTP_SECRET=  # Leave empty to disable TOTP

# Nubra.io Market Data API (optional — provides exchange-sourced NSE/BSE data)
# Sign up at https://nubra.io for a free trading account
# NUBRA_PHONE_NO=your_registered_phone_number
# NUBRA_MPIN=your_4_digit_mpin
# NUBRA_ENV=PROD
# NUBRA_TOTP_SECRET=your_totp_secret_for_automated_login
